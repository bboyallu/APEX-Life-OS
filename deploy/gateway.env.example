# APEX gateway environment — copy to /etc/apex/gateway.env and fill in.
# Keep this file chmod 600; it holds secrets.

# Telegram bot token from @BotFather (required for the gateway)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat ids allowed to talk to APEX (recommended).
# Leave empty to allow anyone who finds the bot (not recommended).
TELEGRAM_ALLOWED_CHAT_IDS=

# LLM provider API key (see `apex model` for providers)
APEX_API_KEY=

# Optional overrides
#APEX_BASE_URL=
#APEX_MODEL=
